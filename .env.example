# ── LLM Providers ──────────────────────────────────────
OLLAMA_API_KEY=your-ollama-cloud-key-here                  # Ollama Cloud — ollama.com
OLLAMA_BASE_URL=http://localhost:11434                     # Local Ollama, Ollama Cloud, or OpenAI-compatible /v1 endpoint
OLLAMA_EMBEDDING_MODEL=nomic-embed-text                    # Embedding model used for news RAG

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fluss

# ── Market Data ────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here          # Alpha Vantage — alphavantage.co
COINGECKO_API_KEY=your-coingecko-key-here                  # CoinGecko — coingecko.com (optional, free tier works without key)
NEWS_API_KEY=your-newsapi-key-here                         # NewsAPI — newsapi.org
FRED_API_KEY=your-fred-key-here                            # FRED — fred.stlouisfed.org

# ── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ORCHESTRATOR_TICK_INTERVAL_MS=900000                       # 15 minutes
